{
  "name": "@promptlm/client-sdk-ts",
  "version": "0.1.0",
  "description": "TypeScript SDK for promptLM JSON prompt bundles",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "resources"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "tsx --test test/**/*.test.ts",
    "smoke": "node scripts/smoke-install.mjs",
    "verify": "npm run build && npm run test && npm run smoke"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
